{
	"compatibility_date": "2026-04-04",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"name": "austinrehorn-site-v2",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "austinrehorn-site",
			"database_id": "a70318ce-95a8-4d18-a9a2-e509518c71bb"
		}
	]
}