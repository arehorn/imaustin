---
import { sanityClient } from "sanity:client";
import { PortableText } from "@portabletext/react";
import Layout from "../../layouts/Layout.astro";
import { imageUrl } from "../../lib/sanity";
import { BLOG_POST_QUERY } from "../../lib/queries";

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/blog");

const client = sanityClient;

type BlogPost = {
  _id: string;
  title: string;
  slug: string;
  excerpt?: string;
  publishedDate?: string;
  tags?: string[];
  coverImage?: unknown;
  coverImageAlt?: string;
  body?: unknown;
};

const post = await client.fetch<BlogPost | null>(BLOG_POST_QUERY, { slug });

if (!post) return Astro.redirect("/blog");

const tags = Array.isArray(post.tags) ? post.tags : [];
const coverUrl = imageUrl(post.coverImage as any, { width: 1400, quality: 85 });
---
<Layout title={`${post.title} — Austin Rehorn`} description={post.excerpt}>
  <main class="relative min-h-screen pt-40 pb-20">
    <div class="max-w-3xl mx-auto px-6">

      <a href="/blog" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.3em] text-gray-500 hover:text-[#00F2FF] transition-colors mb-12">
        <span>←</span>
        <span>Back to Notes</span>
      </a>

      <div class="mb-12">
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.map((tag: string) => (
            <span class="tag-pill px-3 py-1 text-[10px] font-medium uppercase tracking-widest">{tag}</span>
          ))}
        </div>

        <h1 class="font-['Plus_Jakarta_Sans'] font-extrabold text-4xl lg:text-6xl leading-[1.05] tracking-tighter mb-6 text-white">
          {post.title}
        </h1>

        {post.publishedDate && (
          <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[#00F2FF]">
            Published {new Date(post.publishedDate).toLocaleDateString("en-US", {
              month: "long",
              day: "numeric",
              year: "numeric",
            })}
          </p>
        )}
      </div>

      {coverUrl && (
        <div class="relative w-full h-96 rounded-[2rem] overflow-hidden mb-12 glass-card p-2">
          <div class="absolute -inset-2 bg-gradient-to-tr from-[#7000FF]/30 to-[#00F2FF]/30 opacity-40 blur-2xl pointer-events-none" aria-hidden="true"></div>
          <img
            src={coverUrl}
            alt={post.coverImageAlt || post.title}
            class="relative w-full h-full object-cover rounded-[1.6rem] brightness-90 contrast-110"
          />
        </div>
      )}

      {post.body && (
        <div class="prose-invert-custom prose-lg max-w-none mb-16 text-gray-300 leading-relaxed">
          <PortableText value={post.body as any} />
        </div>
      )}

      <div class="pt-12 border-t border-white/10">
        <a href="/blog" class="inline-flex items-center gap-3 px-6 py-3 rounded-full glass-card text-sm font-bold text-white hover:bg-white/10 transition-all">
          <span>←</span>
          <span>Back to Notes</span>
        </a>
      </div>

    </div>
  </main>
</Layout>
