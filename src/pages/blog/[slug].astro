---
import { sanityClient } from "sanity:client";
import { PortableText } from "@portabletext/react";
import Layout from "../../layouts/Layout.astro";
import { imageUrl } from "../../lib/sanity";
import { BLOG_POST_QUERY } from "../../lib/queries";

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/blog");

const client = sanityClient;

type BlogPost = {
  _id: string;
  title: string;
  slug: string;
  excerpt?: string;
  publishedDate?: string;
  tags?: string[];
  coverImage?: unknown;
  coverImageAlt?: string;
  body?: unknown;
};

const post = await client.fetch<BlogPost | null>(BLOG_POST_QUERY, { slug });

if (!post) return Astro.redirect("/blog");

const tags = Array.isArray(post.tags) ? post.tags : [];
const coverUrl = imageUrl(post.coverImage as any, { width: 1400, quality: 85 });
---
<Layout title={`${post.title} — Austin Rehorn`} description={post.excerpt}>
  <main class="min-h-screen pt-28 pb-20">
    <div class="max-w-3xl mx-auto px-6">

      <a href="/blog" class="inline-flex items-center gap-2 text-sm text-[#6B7280] hover:text-[#3D4852] transition-colors mb-12">
        <span>←</span>
        <span>Back to Notes</span>
      </a>

      <div class="mb-12">
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.map((tag: string) => (
            <span class="neu-tag px-3 py-1 rounded-full text-xs font-medium text-[#6B7280] bg-[#E0E5EC]">{tag}</span>
          ))}
        </div>

        <h1 class="font-display font-extrabold text-[#3D4852] text-4xl lg:text-5xl leading-[1.1] tracking-tight mb-6">
          {post.title}
        </h1>

        {post.publishedDate && (
          <p class="text-sm text-[#9CA3AF]">
            Published {new Date(post.publishedDate).toLocaleDateString("en-US", {
              month: "long",
              day: "numeric",
              year: "numeric",
            })}
          </p>
        )}
      </div>

      {coverUrl && (
        <div class="relative w-full h-96 rounded-3xl overflow-hidden mb-12 neu-card">
          <img
            src={coverUrl}
            alt={post.coverImageAlt || post.title}
            class="w-full h-full object-cover"
          />
        </div>
      )}

      {post.body && (
        <div class="prose prose-lg max-w-none mb-16">
          <PortableText value={post.body as any} />
        </div>
      )}

      <div class="pt-12 border-t border-[#D1D5DB]">
        <a href="/blog" class="inline-flex items-center gap-2 px-6 py-3 rounded-full neu-btn-secondary text-sm font-medium text-[#3D4852] hover:scale-[1.02] transition-transform duration-200">
          <span>←</span>
          <span>Back to Notes</span>
        </a>
      </div>

    </div>
  </main>
</Layout>
