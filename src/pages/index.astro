---
import { sanityClient } from "sanity:client";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import WhatIDo from "../components/WhatIDo.astro";
import Projects from "../components/Projects.astro";
import Experience from "../components/Experience.astro";
import Connect from "../components/Connect.astro";
import { imageUrl } from "../lib/sanity";
import {
  HERO_QUERY,
  ABOUT_QUERY,
  ABOUT_STATS_QUERY,
  PERSONALITY_CARDS_QUERY,
  OFF_CLOCK_NOTES_QUERY,
  SERVICE_COLUMNS_QUERY,
  PROJECTS_QUERY,
  EXPERIENCE_QUERY,
  EXPERIENCE_ROLES_QUERY,
  EXPERIENCE_STATS_QUERY,
  CONNECT_QUERY,
  CONTACT_ITEMS_QUERY,
} from "../lib/queries";
import type {
  HeroData, AboutData, StatItem, PersonalityCard, OffClockNote,
  ServiceColumn, ProjectItem, ExperienceData, ExperienceRole,
  ConnectData, ContactItem,
} from "../types/emdash";

const client = sanityClient;

// Fetch everything in parallel. Each item is the raw Sanity shape;
// we reshape below so existing components keep their prop contracts.
const [
  heroRaw,
  aboutRaw,
  aboutStatsRaw,
  personalityCardsRaw,
  offClockNotesRaw,
  serviceColumnsRaw,
  projectsRaw,
  experienceRaw,
  experienceRolesRaw,
  experienceStatsRaw,
  connectRaw,
  contactItemsRaw,
] = await Promise.all([
  client.fetch<any>(HERO_QUERY),
  client.fetch<any>(ABOUT_QUERY),
  client.fetch<any[]>(ABOUT_STATS_QUERY),
  client.fetch<any[]>(PERSONALITY_CARDS_QUERY),
  client.fetch<any[]>(OFF_CLOCK_NOTES_QUERY),
  client.fetch<any[]>(SERVICE_COLUMNS_QUERY),
  client.fetch<any[]>(PROJECTS_QUERY),
  client.fetch<any>(EXPERIENCE_QUERY),
  client.fetch<any[]>(EXPERIENCE_ROLES_QUERY),
  client.fetch<any[]>(EXPERIENCE_STATS_QUERY),
  client.fetch<any>(CONNECT_QUERY),
  client.fetch<any[]>(CONTACT_ITEMS_QUERY),
]);

// ── Adapters: map Sanity → legacy emDash shapes so components stay untouched.

const hero: HeroData = {
  id: "hero",
  badge_text: heroRaw?.badgeText ?? "",
  headline: heroRaw?.headline ?? "",
  subheading: heroRaw?.subheading ?? "",
  cta_text: heroRaw?.ctaText ?? "",
  headshot_url: imageUrl(heroRaw?.headshot, { width: 1000, quality: 85 }),
  headshot_alt: heroRaw?.headshotAlt ?? "",
  resume_url: heroRaw?.resumeUrl ?? "",
};

const about: AboutData = {
  id: "about",
  heading: aboutRaw?.heading ?? "",
  bio_paragraph_1: aboutRaw?.bioParagraph1 ?? "",
  bio_paragraph_2: aboutRaw?.bioParagraph2 ?? "",
  quote: aboutRaw?.quote ?? "",
  closing_statement: aboutRaw?.closingStatement ?? "",
  photo_url: imageUrl(aboutRaw?.photo, { width: 800, quality: 85 }),
  photo_alt: aboutRaw?.photoAlt ?? "",
};

const aboutStats: StatItem[] = (aboutStatsRaw ?? []).map((s: any) => ({
  id: s._id,
  value: s.value,
  label: s.label,
}));

const personalityCards: PersonalityCard[] = (personalityCardsRaw ?? []).map((c: any) => ({
  id: c._id,
  title: c.title,
  description: c.description ?? "",
  icon: c.icon ?? "star",
  accent_color: c.accentColor ?? "",
}));

const offClockNotes: OffClockNote[] = (offClockNotesRaw ?? []).map((n: any) => ({
  id: n._id,
  label: n.label,
  value: n.value,
}));

const serviceColumns: ServiceColumn[] = (serviceColumnsRaw ?? []).map((c: any) => ({
  id: c._id,
  title: c.title,
  bullets: Array.isArray(c.bullets) ? c.bullets.join("\n") : (c.bullets ?? ""),
  icon_type: c.iconType ?? "people",
}));

const projects: ProjectItem[] = (projectsRaw ?? []).map((p: any) => {
  let tags: string[] = [];
  if (Array.isArray(p.tags)) {
    tags = p.tags;
  } else if (typeof p.tags === "string") {
    tags = p.tags.split(",").map((t: string) => t.trim()).filter(Boolean);
  }
  return {
    id: p._id,
    title: p.title,
    description: p.description ?? "",
    tags,
    href: p.href ?? "",
  };
});

const experienceRoles: ExperienceRole[] = (experienceRolesRaw ?? []).map((r: any) => ({
  id: r._id,
  title: r.title,
  company: r.company,
  division: r.division ?? "",
  dates: r.dates ?? "",
  era: r.era ?? "",
  side: (r.side ?? "left") as "left" | "right",
  icon_type: r.iconType ?? "briefcase",
  highlights: Array.isArray(r.highlights) ? r.highlights.join("\n") : (r.highlights ?? ""),
}));

const experienceStats: StatItem[] = (experienceStatsRaw ?? []).map((s: any) => ({
  id: s._id,
  value: s.value,
  label: s.label,
}));

const experience: ExperienceData = {
  id: "experience",
  section_heading: experienceRaw?.sectionHeading ?? "",
  section_subheading: experienceRaw?.sectionSubheading ?? "",
  roles: experienceRoles,
  stats: experienceStats,
  cta_heading: experienceRaw?.ctaHeading ?? "",
  cta_subheading: experienceRaw?.ctaSubheading ?? "",
  headshot_url: imageUrl(experienceRaw?.headshot, { width: 800, quality: 85 }),
  headshot_alt: experienceRaw?.headshotAlt ?? "",
};

const contactItems: ContactItem[] = (contactItemsRaw ?? []).map((c: any) => ({
  id: c._id,
  label: c.label,
  value: c.value,
  href: c.href ?? "",
  icon_type: c.iconType ?? "email",
}));

const connect: ConnectData = {
  id: "connect",
  quote: connectRaw?.quote ?? "",
  photo_url: imageUrl(connectRaw?.photo, { width: 800, quality: 85 }),
  photo_alt: connectRaw?.photoAlt ?? "",
  contact_items: contactItems,
};
---
<Layout>
  <main>
    <Hero hero={hero} />
    <About
      about={about}
      stats={aboutStats}
      personalityCards={personalityCards}
      offClockNotes={offClockNotes}
    />
    <WhatIDo columns={serviceColumns} />
    <Projects projects={projects} />
    <Experience
      sectionHeading={experience.section_heading}
      sectionSubheading={experience.section_subheading}
      roles={experienceRoles}
      stats={experienceStats}
      ctaHeading={experience.cta_heading}
      ctaSubheading={experience.cta_subheading}
      headshotUrl={experience.headshot_url}
      headshotAlt={experience.headshot_alt}
    />
    <Connect connect={connect} contactItems={contactItems} />
  </main>
</Layout>
