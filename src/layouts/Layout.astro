---
import "../styles/globals.css";
import Nav from "../components/Nav";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Austin Rehorn — Enterprise Account Management & AI Automation",
  description = "Trust and Relationships by choice, AI automation by necessity. Enterprise account manager and AI builder based in Mt. Pleasant, SC.",
} = Astro.props;
---
<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-full flex flex-col" style="background-color: #0b1326; color: #dae2fd;">
    <Nav client:load />
    <slot />
    <footer class="py-10">
      <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">
        <p class="text-sm" style="color: #c6c6cd;">© {new Date().getFullYear()} Austin Rehorn</p>
        <div
          class="w-8 h-1 rounded-full"
          style="background: linear-gradient(90deg, #c3c0ff, #7bd0ff)"
        />
      </div>
    </footer>
  </body>
</html>
