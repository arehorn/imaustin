---
import type { HeroData } from "../types/emdash";

interface Props {
  hero: HeroData;
}

const { hero } = Astro.props;
---

<section id="hero" class="relative min-h-screen flex items-center pt-20 overflow-hidden">
  <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-md-primary/10 blur-3xl rounded-full" aria-hidden="true" />
  <div class="max-w-6xl mx-auto px-6 py-24 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.4fr] gap-12 items-center">

      {/* Text */}
      <div>
        {/* Eyebrow */}
        <div class="inline-flex items-center gap-2 neu-label px-4 py-2 rounded-full mb-8 animate-fade-in-up">
          <span class="w-2 h-2 rounded-full bg-[#6C63FF] inline-block" />
          <span class="text-xs font-semibold tracking-widest text-[#6B7280] uppercase">
            {hero.badge_text}
          </span>
        </div>

        <h1 class="font-display font-extrabold text-[#3D4852] text-4xl sm:text-5xl lg:text-[3.25rem] leading-[1.1] tracking-tight mb-6 animate-fade-in-up animation-delay-100">
          {hero.headline}
        </h1>

        <p class="text-[#6B7280] text-lg leading-relaxed mb-10 max-w-lg animate-fade-in-up animation-delay-200">
          {hero.subheading}
        </p>

        <div class="flex flex-wrap gap-4 mb-10 animate-fade-in-up animation-delay-300">
          <a
            href="#work"
            class="neu-btn-primary font-display font-semibold px-7 py-3.5 rounded-2xl text-sm tracking-wide"
          >
            See My Work
          </a>
          <a
            href="#connect"
            class="neu-btn-secondary font-display font-semibold px-7 py-3.5 rounded-2xl text-sm tracking-wide"
          >
            Let&apos;s Connect
          </a>
          {hero.resume_file_url && (
            <a
              href={hero.resume_url}
              download
              class="neu-btn-secondary font-display font-semibold px-7 py-3.5 rounded-2xl text-sm tracking-wide inline-flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Download Resume
            </a>
          )}
        </div>

        <p class="text-sm text-[#6B7280] animate-fade-in-up animation-delay-400">
          {hero.cta_text}
        </p>
      </div>

      {/* Headshot in Neumorphic Orb */}
      <div class="hidden lg:flex items-center justify-center">
        <div class="animate-float">
          <div
            class="rounded-full bg-[#E0E5EC] flex items-center justify-center"
            style="width: 700px; height: 700px; box-shadow: 18px 18px 36px rgb(163 177 198 / 0.65), -18px -18px 36px rgba(255 255 255 / 0.62);"
          >
            <div
              class="rounded-full bg-[#E0E5EC] flex items-center justify-center"
              style="width: 600px; height: 600px; box-shadow: inset 12px 12px 24px rgb(163 177 198 / 0.7), inset -12px -12px 24px rgba(255 255 255 / 0.6);"
            >
              <div
                class="rounded-full overflow-hidden"
                style="width: 500px; height: 500px; box-shadow: 0 0 0 4px rgba(108, 99, 255, 0.2), 8px 8px 18px rgb(163 177 198 / 0.5), -8px -8px 18px rgba(255 255 255 / 0.5);"
              >
                <img
                  src={hero.headshot_url}
                  alt={hero.headshot_alt || "Austin Rehorn"}
                  width="500"
                  height="500"
                  class="w-full h-full object-cover object-top"
                  loading="eager"
                />
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
