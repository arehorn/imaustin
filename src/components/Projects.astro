---
import type { ProjectItem } from '../types/emdash';

interface Props {
  projects: ProjectItem[];
}

const { projects } = Astro.props;
---

<section id="work" class="py-28">
  <div class="max-w-6xl mx-auto px-6">

    <div class="inline-flex items-center gap-2 neu-label px-4 py-2 rounded-full mb-12">
      <span class="text-xs font-semibold tracking-widest text-[#6B7280] uppercase">Featured Work</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project: ProjectItem) => {
        const tags = project.tags.split(",").map((t) => t.trim()).filter(Boolean);
        return (
          <div
            class="neu-card rounded-[32px] bg-[#E0E5EC] p-8 flex flex-col"
          >
            <div
              class="w-10 h-1.5 rounded-full mb-6"
              style={{ background: "linear-gradient(90deg, #6C63FF, #8B84FF)", boxShadow: "0 0 8px rgba(108 99 255 / 0.4)" }}
            />

            <h3 class="font-display font-bold text-[#3D4852] text-xl mb-3 tracking-tight">
              {project.title}
            </h3>
            <p class="text-[#6B7280] text-sm leading-relaxed mb-8 flex-1">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span
                  class="neu-tag px-3 py-1.5 rounded-full text-xs font-medium text-[#6B7280] bg-[#E0E5EC]"
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>
