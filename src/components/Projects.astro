---
import type { ProjectItem } from '../types/emdash';

interface Props {
  projects: ProjectItem[];
}

const { projects } = Astro.props;
---

<section id="work" class="py-28" style="background-color: #0b1326;">
  <div class="max-w-6xl mx-auto px-6">

    <div class="inline-flex items-center gap-2 label-pill px-4 py-2 mb-12">
      <span class="text-xs font-semibold tracking-widest uppercase" style="color: #c6c6cd;">Featured Work</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project: ProjectItem) => {
        const tags = project.tags.split(",").map((t) => t.trim()).filter(Boolean);
        return (
          <div
            class="rounded-[32px] p-8 flex flex-col"
            style="background-color: #131b2e; box-shadow: 0 8px 24px rgba(195,192,255,0.04), 0 2px 8px rgba(0,0,0,0.3);"
          >
            <div
              class="w-10 h-1.5 rounded-full mb-6"
              style="background: linear-gradient(90deg, #c3c0ff, #7bd0ff); box-shadow: 0 0 8px rgba(195,192,255,0.3);"
            />

            <h3 class="font-display font-bold text-xl mb-3 tracking-tight" style="color: #dae2fd;">
              {project.title}
            </h3>
            <p class="text-sm leading-relaxed mb-8 flex-1" style="color: #c6c6cd;">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span
                  class="tag-pill px-3 py-1.5 rounded-full text-xs font-medium"
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>
