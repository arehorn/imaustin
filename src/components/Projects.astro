---
import type { ProjectItem } from '../types/emdash';

interface Props {
  projects: ProjectItem[];
}

const { projects } = Astro.props;

const ACCENT_CYCLE = [
  { from: "#00F2FF", to: "#7000FF", border: "hover:border-[#00F2FF]/50" },
  { from: "#7000FF", to: "#00F2FF", border: "hover:border-[#7000FF]/50" },
] as const;
---

<section id="work" class="relative py-28">
  <div class="max-w-7xl mx-auto px-6">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 border-l-4 border-[#00F2FF] pl-8 mb-20">
      <div class="space-y-4">
        <span class="text-[#00F2FF] font-bold uppercase tracking-[0.4em] text-xs">Featured Work</span>
        <h2 class="text-4xl lg:text-5xl font-extrabold font-['Plus_Jakarta_Sans'] text-white tracking-tighter">
          Signal in the noise.
        </h2>
      </div>
      <p class="text-gray-500 max-w-md italic text-lg">
        Projects where strategy met shipping.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 pt-6">
      {projects.map((project: ProjectItem, i: number) => {
        const tags = project.tags.split(",").map((t) => t.trim()).filter(Boolean);
        const accent = ACCENT_CYCLE[i % ACCENT_CYCLE.length];
        return (
          <div
            class={`staggered-item rounded-[2.5rem] p-10 glass-card flex flex-col group hover:-translate-y-4 transition-all duration-500 ${accent.border}`}
          >
            <div
              class="w-16 h-1.5 rounded-full mb-8"
              style={`background: linear-gradient(90deg, ${accent.from}, ${accent.to}); box-shadow: 0 0 15px ${accent.from}80;`}
            />

            <h3 class="font-['Plus_Jakarta_Sans'] font-bold text-2xl mb-4 tracking-tighter text-white leading-tight">
              {project.title}
            </h3>
            <p class="text-base leading-relaxed mb-8 flex-1 text-gray-400">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="tag-pill px-3 py-1.5 text-xs font-medium uppercase tracking-wider">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>
