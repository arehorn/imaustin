---
import type { ConnectData, ContactItem } from "../types/emdash";
import ContactForm from "./ContactForm";

interface Props {
  connect: ConnectData;
}

const { connect } = Astro.props;

const CONTACT_ICON_PATHS: Record<string, string> = {
  email: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  phone: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z",
  linkedin: "M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z",
  location: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z",
};

const quoteParts = connect.quote.split("—");
const quoteMain = quoteParts[0];
const quoteAccent = quoteParts[1]?.trim();
---

<section id="connect" class="py-28">
  <div class="max-w-6xl mx-auto px-6">

    <div class="inline-flex items-center gap-2 neu-label px-4 py-2 rounded-full mb-12">
      <span class="text-xs font-semibold tracking-widest text-[#6B7280] uppercase">Let&apos;s Connect</span>
    </div>

    <!-- Photo + quote banner -->
    <div class="neu-extruded rounded-[32px] bg-[#E0E5EC] p-10 md:p-14 mb-10 flex flex-col md:flex-row gap-10 items-center">
      <div class="shrink-0">
        <div
          class="rounded-2xl overflow-hidden"
          style="width: 200px; height: 240px; box-shadow: 8px 8px 18px rgb(163 177 198 / 0.6), -8px -8px 18px rgba(255 255 255 / 0.55);"
        >
          <img
            src={connect.photo_url}
            alt={connect.photo_alt || "Austin Rehorn"}
            width="200"
            height="240"
            class="w-full h-full object-cover object-top"
          />
        </div>
      </div>
      <p class="font-display font-bold text-[#3D4852] text-2xl md:text-3xl leading-snug tracking-tight">
        {quoteMain}—{" "}
        <span class="text-[#6C63FF]">{quoteAccent}</span>
      </p>
    </div>

    <!-- Contact items grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
      {connect.contact_items.map((item: ContactItem) => {
        const iconPath = CONTACT_ICON_PATHS[item.icon_type] ?? CONTACT_ICON_PATHS.email;
        return (
          <div class="neu-card rounded-[32px] bg-[#E0E5EC] p-7 flex gap-5 items-center">
            <div
              class="shrink-0 w-12 h-12 rounded-2xl bg-[#E0E5EC] flex items-center justify-center"
              style="box-shadow: inset 6px 6px 12px rgb(163 177 198 / 0.65), inset -6px -6px 12px rgba(255 255 255 / 0.6);"
            >
              <svg class="w-5 h-5 text-[#6C63FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPath} />
              </svg>
            </div>
            <div class="min-w-0">
              <p class="text-xs font-semibold tracking-widest text-[#6B7280] uppercase mb-1">{item.label}</p>
              {item.href ? (
                <a
                  href={item.href}
                  target={item.href.startsWith("http") ? "_blank" : undefined}
                  rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
                  class="font-display font-semibold text-[#3D4852] hover:text-[#6C63FF] transition-colors duration-300 text-sm truncate block"
                >
                  {item.value}
                </a>
              ) : (
                <p class="font-display font-semibold text-[#3D4852] text-sm">{item.value}</p>
              )}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Contact form (React island) -->
    <ContactForm client:load />

  </div>
</section>
