# emdash CMS Configuration
# The following are optional - emdash auto-configures with local SQLite by default

# DATABASE_URL=file:./.emdash/d1.sqlite
# STORAGE_PATH=./.emdash/uploads

# For production emdash deployment (optional)
# DATABASE_URL=postgresql://user:password@host/database
# S3_ENDPOINT=https://...
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...

# Claude API (Phase 2 - Chatbot)
# ANTHROPIC_API_KEY=sk-ant-...
# VITE_CHATBOT_ENABLED=true

# Analytics (optional)
# VITE_GA_ID=G-...

# Site Configuration
# VITE_SITE_URL=https://imaustin.me
